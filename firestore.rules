rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Each user can only read/write their own data (profile doc and all
    // subcollections: library, chats, jamPresets, ...).
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    // Shared content ("shares" collection) is only accessed through the
    // backend with the Admin SDK, so no client access is granted here.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
