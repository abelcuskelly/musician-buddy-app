# --- Backend (Gemini + Lyria, service-account auth) ---
# No API keys: chat, TTS, and STT authenticate through Vertex AI and Lyria
# through the Gemini Interactions API, all as the service account.
# On Cloud Run the attached service account is used automatically.
# Locally: `gcloud auth application-default login` (your user must have
# roles/iam.serviceAccountTokenCreator on the service account so the Lyria
# call can impersonate it).
VERTEX_LOCATION=global

# Optional overrides (defaults shown)
# LYRIA_SERVICE_ACCOUNT=243585371458-compute@developer.gserviceaccount.com
# GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview
# GEMINI_TTS_VOICE=Kore
# GEMINI_STT_MODEL=gemini-3-flash-preview

# --- Frontend (Firebase) ---
# Used by the React app for sign-in (Google / Apple / Email+Password)
# and for saving lesson plans, songs, and audio to user profiles.
# Find these values in the Firebase Console:
#   Project settings -> General -> Your apps -> SDK setup and configuration
# See AUTH_SETUP.md for full setup instructions.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
