# --- Backend (Gemini) ---
# Used by the Express server to call the Gemini API.
GEMINI_API_KEY=your_gemini_api_key_here

# --- Frontend (Firebase) ---
# Used by the React app for sign-in (Google / Apple / Email+Password)
# and for saving lesson plans, songs, and audio to user profiles.
# Find these values in the Firebase Console:
#   Project settings -> General -> Your apps -> SDK setup and configuration
# See AUTH_SETUP.md for full setup instructions.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
