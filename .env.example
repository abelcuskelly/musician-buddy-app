# --- Backend (Gemini via Vertex AI) ---
# Chat, TTS, and STT authenticate as a service account via Application Default
# Credentials — no API key. Locally: `gcloud auth application-default login`.
# On Cloud Run the attached service account is used automatically.
VERTEX_LOCATION=global

# Lyria audio generation is not served by Vertex AI and still uses the Gemini
# Developer API. In production this is injected from Secret Manager
# (musician-buddy-api-key), not stored in plaintext.
GEMINI_API_KEY=your_gemini_api_key_for_lyria_only

# Optional voice model overrides (defaults shown)
# GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview
# GEMINI_TTS_VOICE=Kore
# GEMINI_STT_MODEL=gemini-3-flash-preview

# --- Frontend (Firebase) ---
# Used by the React app for sign-in (Google / Apple / Email+Password)
# and for saving lesson plans, songs, and audio to user profiles.
# Find these values in the Firebase Console:
#   Project settings -> General -> Your apps -> SDK setup and configuration
# See AUTH_SETUP.md for full setup instructions.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
